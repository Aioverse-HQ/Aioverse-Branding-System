<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>AIOVERSE — Brand Assets Naming Package</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap');

:root {
–aqua:    #00E5FF;
–teal:    #0D7377;
–soft:    #E8F4F8;
–bg:      #050A0F;
–surface: rgba(255,255,255,0.04);
–border:  rgba(0,229,255,0.12);
–text:    #C8D8E0;
–dim:     #5A7080;
–green:   #00FFB0;
–amber:   #FFB830;
–red:     #FF4D6D;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
font-family: ‘DM Sans’, sans-serif;
background: var(–bg);
color: var(–text);
min-height: 100vh;
overflow-x: hidden;
}

/* ── Animated Background ── */
.bg-orbs {
position: fixed; inset: 0; pointer-events: none; z-index: 0;
overflow: hidden;
}
.orb {
position: absolute; border-radius: 50%;
filter: blur(100px); opacity: 0.18; animation: drift 20s ease-in-out infinite alternate;
}
.orb-1 { width: 600px; height: 600px; background: var(–aqua);  top: -200px; left: -100px; animation-delay: 0s; }
.orb-2 { width: 500px; height: 500px; background: var(–teal);  bottom: -100px; right: -100px; animation-delay: -7s; }
.orb-3 { width: 300px; height: 300px; background: #7B2FBE; top: 40%; left: 50%; animation-delay: -13s; }
@keyframes drift { 0% { transform: translate(0,0) scale(1); } 100% { transform: translate(40px, 30px) scale(1.08); } }

/* ── Layout ── */
.wrap {
position: relative; z-index: 1;
max-width: 1100px; margin: 0 auto;
padding: 0 24px 80px;
}

/* ── Header ── */
header {
display: flex; align-items: center; justify-content: space-between;
padding: 28px 0 20px;
border-bottom: 1px solid var(–border);
margin-bottom: 48px;
}
.logo-text {
font-family: ‘Syne’, sans-serif; font-size: 18px; font-weight: 800;
letter-spacing: 0.12em; color: var(–aqua);
}
.logo-text span { color: var(–soft); opacity: 0.5; font-weight: 400; }
.badge {
font-family: ‘JetBrains Mono’, monospace; font-size: 10px;
color: var(–aqua); border: 1px solid var(–border);
background: rgba(0,229,255,0.06); padding: 4px 10px; border-radius: 20px;
letter-spacing: 0.1em;
}

/* ── Hero ── */
.hero { margin-bottom: 60px; }
.hero-tag {
font-family: ‘JetBrains Mono’, monospace; font-size: 11px;
color: var(–teal); letter-spacing: 0.15em; text-transform: uppercase;
margin-bottom: 16px;
}
.hero h1 {
font-family: ‘Syne’, sans-serif; font-size: clamp(32px, 5vw, 56px);
font-weight: 800; line-height: 1.1; color: var(–soft);
margin-bottom: 20px;
}
.hero h1 em { font-style: normal; color: var(–aqua); }
.hero p { font-size: 15px; color: var(–dim); line-height: 1.8; max-width: 600px; }

/* ── Tabs ── */
.tabs {
display: flex; gap: 4px; margin-bottom: 32px;
background: var(–surface); border: 1px solid var(–border);
border-radius: 10px; padding: 4px;
width: fit-content;
}
.tab {
font-family: ‘JetBrains Mono’, monospace; font-size: 11px; font-weight: 500;
letter-spacing: 0.08em; padding: 8px 16px; border-radius: 7px; cursor: pointer;
border: none; background: transparent; color: var(–dim);
transition: all 0.2s;
}
.tab:hover { color: var(–text); }
.tab.active {
background: rgba(0,229,255,0.12); color: var(–aqua);
border: 1px solid rgba(0,229,255,0.25);
}

/* ── Sections ── */
.section { display: none; }
.section.active { display: block; }

/* ── Glass Card ── */
.glass {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 14px;
backdrop-filter: blur(12px);
-webkit-backdrop-filter: blur(12px);
}

/* ── Convention Banner ── */
.convention-banner {
background: linear-gradient(135deg, rgba(0,229,255,0.08), rgba(13,115,119,0.12));
border: 1px solid rgba(0,229,255,0.2);
border-radius: 14px; padding: 28px 32px; margin-bottom: 36px;
}
.convention-banner h2 {
font-family: ‘Syne’, sans-serif; font-size: 13px; font-weight: 700;
letter-spacing: 0.15em; text-transform: uppercase; color: var(–aqua);
margin-bottom: 16px;
}
.pattern-box {
font-family: ‘JetBrains Mono’, monospace; font-size: 16px;
color: var(–soft); background: rgba(0,0,0,0.3);
border: 1px solid rgba(0,229,255,0.15); border-radius: 8px;
padding: 14px 20px; margin-bottom: 20px; letter-spacing: 0.04em;
}
.pattern-box .seg { color: var(–aqua); }
.pattern-box .sep { color: var(–dim); }
.pattern-box .opt { color: var(–amber); }

.segments-grid {
display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
gap: 12px;
}
.seg-card {
background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.07);
border-radius: 8px; padding: 12px 16px;
}
.seg-card .seg-name {
font-family: ‘JetBrains Mono’, monospace; font-size: 10px;
color: var(–aqua); letter-spacing: 0.1em; margin-bottom: 6px;
}
.seg-card .seg-vals {
font-size: 11px; color: var(–dim); line-height: 1.9;
}
.seg-card .seg-vals code {
color: var(–text); background: rgba(255,255,255,0.05);
padding: 1px 5px; border-radius: 3px; font-size: 10px;
}

/* ── Folder Tree ── */
.tree-wrap { padding: 28px 32px; }
.tree-wrap h2 {
font-family: ‘Syne’, sans-serif; font-weight: 700; font-size: 13px;
letter-spacing: 0.15em; text-transform: uppercase; color: var(–aqua);
margin-bottom: 20px;
}
.tree { font-family: ‘JetBrains Mono’, monospace; font-size: 12.5px; line-height: 2; }
.tree .folder { color: var(–aqua); font-weight: 500; }
.tree .file   { color: var(–text); }
.tree .file.svg  { color: #00FFB0; }
.tree .file.webp { color: #64B5F6; }
.tree .file.zip  { color: var(–amber); }
.tree .file.ai   { color: #FF9E64; }
.tree .file.png  { color: #C792EA; }
.tree .file.md   { color: var(–dim); }
.tree .tree-line { color: var(–dim); }

/* ── Rename Table ── */
.rename-header {
padding: 20px 28px; border-bottom: 1px solid var(–border);
display: flex; align-items: center; justify-content: space-between;
}
.rename-header h2 {
font-family: ‘Syne’, sans-serif; font-weight: 700; font-size: 13px;
letter-spacing: 0.15em; text-transform: uppercase; color: var(–aqua);
}
.count-badge {
font-family: ‘JetBrains Mono’, monospace; font-size: 11px;
color: var(–green); background: rgba(0,255,176,0.08);
border: 1px solid rgba(0,255,176,0.2); padding: 3px 10px; border-radius: 20px;
}
.filter-row {
padding: 16px 28px; border-bottom: 1px solid var(–border);
display: flex; gap: 8px; flex-wrap: wrap;
}
.filter-btn {
font-family: ‘JetBrains Mono’, monospace; font-size: 10px;
letter-spacing: 0.08em; padding: 5px 12px; border-radius: 6px;
border: 1px solid var(–border); background: transparent;
color: var(–dim); cursor: pointer; transition: all 0.2s;
}
.filter-btn:hover, .filter-btn.active {
background: rgba(0,229,255,0.08); color: var(–aqua);
border-color: rgba(0,229,255,0.3);
}
.rename-table { width: 100%; border-collapse: collapse; }
.rename-table th {
font-family: ‘JetBrains Mono’, monospace; font-size: 10px;
letter-spacing: 0.12em; text-transform: uppercase; color: var(–dim);
padding: 12px 20px; text-align: left; border-bottom: 1px solid var(–border);
background: rgba(0,0,0,0.2);
}
.rename-table td {
padding: 10px 20px; font-family: ‘JetBrains Mono’, monospace; font-size: 11.5px;
border-bottom: 1px solid rgba(255,255,255,0.03); vertical-align: middle;
}
.rename-table tr:hover td { background: rgba(0,229,255,0.03); }
.old-name { color: #FF6B8A; text-decoration: line-through; opacity: 0.7; }
.new-name { color: var(–green); }
.cat-pill {
font-size: 9px; padding: 2px 8px; border-radius: 12px;
font-family: ‘JetBrains Mono’, monospace; letter-spacing: 0.08em;
white-space: nowrap;
}
.cat-logo   { background: rgba(0,229,255,0.1);  color: var(–aqua);  border: 1px solid rgba(0,229,255,0.25); }
.cat-mark   { background: rgba(100,181,246,0.1); color: #64B5F6;     border: 1px solid rgba(100,181,246,0.25); }
.cat-icon   { background: rgba(0,255,176,0.1);  color: var(–green); border: 1px solid rgba(0,255,176,0.25); }
.cat-social { background: rgba(255,184,48,0.1); color: var(–amber); border: 1px solid rgba(255,184,48,0.25); }
.cat-font   { background: rgba(123,47,190,0.15); color: #C792EA;     border: 1px solid rgba(123,47,190,0.3); }
.cat-doc    { background: rgba(90,112,128,0.15); color: var(–dim);   border: 1px solid rgba(90,112,128,0.25); }
.cat-color  { background: rgba(255,77,109,0.1);  color: #FF4D6D;      border: 1px solid rgba(255,77,109,0.25); }
.cat-raw    { background: rgba(255,255,255,0.05); color: #666;        border: 1px solid rgba(255,255,255,0.1); }

/* ── Script / README Panels ── */
.code-panel { padding: 24px 28px; }
.code-panel h2 {
font-family: ‘Syne’, sans-serif; font-weight: 700; font-size: 13px;
letter-spacing: 0.15em; text-transform: uppercase; color: var(–aqua);
margin-bottom: 6px;
}
.code-panel p { font-size: 13px; color: var(–dim); margin-bottom: 20px; }
.code-block {
background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.07);
border-radius: 10px; padding: 20px 24px;
font-family: ‘JetBrains Mono’, monospace; font-size: 12px;
color: var(–text); line-height: 1.9; white-space: pre-wrap;
word-break: break-all; max-height: 500px; overflow-y: auto;
position: relative;
}
.code-block::-webkit-scrollbar { width: 4px; }
.code-block::-webkit-scrollbar-track { background: transparent; }
.code-block::-webkit-scrollbar-thumb { background: rgba(0,229,255,0.2); border-radius: 2px; }
.copy-btn {
position: sticky; float: right; top: 0; right: 0;
font-family: ‘JetBrains Mono’, monospace; font-size: 10px;
letter-spacing: 0.08em; padding: 5px 12px; border-radius: 6px;
border: 1px solid rgba(0,229,255,0.25); background: rgba(0,229,255,0.08);
color: var(–aqua); cursor: pointer; transition: all 0.2s;
}
.copy-btn:hover { background: rgba(0,229,255,0.15); }
.copy-btn.copied { color: var(–green); border-color: rgba(0,255,176,0.3); }

/* sh syntax */
.sh-comment { color: var(–dim); }
.sh-cmd     { color: var(–aqua); }
.sh-str     { color: var(–green); }
.sh-old     { color: #FF6B8A; }
.sh-new     { color: var(–green); }

/* ── Footer ── */
.footer-bar {
margin-top: 64px; padding-top: 24px;
border-top: 1px solid var(–border);
display: flex; align-items: center; justify-content: space-between;
font-family: ‘JetBrains Mono’, monospace; font-size: 11px; color: var(–dim);
}
.footer-bar a { color: var(–aqua); text-decoration: none; }

/* ── Misc ── */
.divider { height: 1px; background: var(–border); margin: 24px 0; }
.note-box {
background: rgba(255,184,48,0.06); border: 1px solid rgba(255,184,48,0.2);
border-radius: 8px; padding: 12px 16px; font-size: 12px;
color: rgba(255,184,48,0.85); margin-bottom: 20px; line-height: 1.7;
}
.note-box strong { font-weight: 600; }

.hidden { display: none !important; }
</style>

</head>
