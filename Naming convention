  const catClass = { logo:'cat-logo', mark:'cat-mark', icon:'cat-icon', social:'cat-social', font:'cat-font', color:'cat-color', doc:'cat-doc', raw:'cat-raw' };
  const catLabel = { logo:'LOGO', mark:'MARK', icon:'ICON', social:'SOCIAL', font:'FONT', color:'COLOR', doc:'DOC', raw:'RAW' };

  function renderTable(filter) {
    const tbody = document.getElementById('rename-body');
    const filtered = filter === 'all' ? renameData : renameData.filter(r => r.cat === filter);
    tbody.innerHTML = filtered.map((r,i) => `
      <tr data-cat="${r.cat}">
        <td style="color:var(--dim);font-size:10px;">${String(i+1).padStart(2,'0')}</td>
        <td class="old-name">${r.old}</td>
        <td class="new-name">${r.new.split('/').pop()}</td>
        <td style="color:var(--dim);font-size:10px;">${r.folder}/</td>
        <td><span class="cat-pill ${catClass[r.cat]}">${catLabel[r.cat]}</span></td>
      </tr>
    `).join('');
    document.getElementById('visible-count').textContent = filtered.length + ' files';
  }

  function filterTable(cat, btn) {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderTable(cat);
  }

  renderTable('all');

  // ── Copy Logic ──
  function copyCode(blockId, btn) {
    const block = document.getElementById(blockId);
    // Get all text, strip the button text
    const text = [...block.childNodes]
      .filter(n => n.nodeType === Node.TEXT_NODE || (n.nodeType === Node.ELEMENT_NODE && !n.classList.contains('copy-btn')))
      .map(n => n.textContent)
      .join('');
    navigator.clipboard.writeText(text.trim()).then(() => {
      btn.textContent = '✓ COPIED';
      btn.classList.add('copied');
      setTimeout(() => { btn.textContent = 'COPY'; btn.classList.remove('copied'); }, 2000);
    });
  }
